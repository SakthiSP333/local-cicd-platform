# Nested repos (pushed separately to their own GitHub repos)
/go-api/
/go-api-helm/

# Claude Code local settings (machine-specific, not project config)
/.claude/

# Downloaded CLI tool binaries (kubectl, helm, yq, trivy, gosec, gitleaks, golangci-lint, minikube)
/bin/

# Harbor is entirely fetched/generated at bootstrap time by install-harbor.sh
# (vendored installer + live secrets/keys/DB data) - nothing here is hand-authored.
/infrastructure/harbor/

# Jenkins runtime state (generated by install-jenkins.sh)
/infrastructure/jenkins/jenkins_home/

# Live credentials generated at bootstrap time
/infrastructure/harbor-robot.env
/infrastructure/argocd-creds.env
/infrastructure/git-daemon.pid
